# Relay environment variables.
# Copy this file to .env.local and fill in the two values.
# Both come from your Upstash Redis database (Vercel KV is Upstash under the hood).
# Never commit .env.local. It is already ignored by .gitignore.

KV_REST_API_URL=
KV_REST_API_TOKEN=

# Note: Aicoo API keys are NOT set here.
# Each member enters their own Aicoo key at connect time. It is stored
# server side in Redis and used only to call that member's own agent.
